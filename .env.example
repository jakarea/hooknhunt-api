APP_NAME="Hook & Hunt ERP"
APP_ENV=local
APP_KEY=base64:+m62I7+myxGZ37fEo5Ejom333rbBuEBvXGFSuzkGDtA=
APP_DEBUG=true
APP_URL=https://hooknhunt-api.test/

APP_TIMEZONE=Asia/Dhaka

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Auth Configuration
AUTH_GUARD=api

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hooknhunt
DB_USERNAME=root
DB_PASSWORD=root

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.hooknhunt.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================
# EPS PAYMENT GATEWAY CONFIGURATION
# ============================================
# EPS (e-Payment Service) - Bangladesh Payment Gateway
# Supports: Internet Banking, Mobile Banking, Card Payments
# Reference: https://github.com/EPS-PG/EPS_Laravel
#
# Official SDK Environment Variables (use these exactly)

# Mode: sandbox or live
EPS_MODE=sandbox

# Base URL (change based on mode)
# Sandbox: https://sandboxpgapi.eps.com.bd
# Live: https://pgapi.eps.com
EPSBaseURL=https://sandboxpgapi.eps.com.bd

# API Credentials
EPSHashkey=
EPSUserName=
EPSPassword=
EPSStoreID=
EPSMerchentID=
EPSDeviceTypeID=0

# Callback URLs (these should point to your API)
EPS_SUCCESS_URL=https://www.hooknhunt.com/api/v2/store/payments/eps/success
EPS_FAIL_URL=https://www.hooknhunt.com/api/v2/store/payments/eps/fail
EPS_CANCEL_URL=https://www.hooknhunt.com/api/v2/store/payments/eps/cancel
EPS_IPN_URL=https://www.hooknhunt.com/api/v2/store/payments/eps/ipn

# Request timeout (seconds)
EPS_TIMEOUT=30

# Verification Settings (for pending payment cron job)
EPS_VERIFICATION_ENABLED=true
EPS_VERIFY_CRON_SECRET=
EPS_VERIFY_CRON_MINUTES=15

# ============================================
# LAZYCHAT INTEGRATION
# ============================================
# Lazychat retail platform webhook configuration
LAZYCHAT_ENABLED=true
LAZYCHAT_WEBHOOK_CREATE_URL=https://flow.lazychat.io/api/exec/flows/69e9bc9f7fd64cf4ca2f9a71/WRkTno7aJAHU
LAZYCHAT_WEBHOOK_CREATE_TOKEN=c2bcecd19a7d0afca4cd4b46aca8ecc194df4de693c0bd1699edd1ccfcbea62b
LAZYCHAT_WEBHOOK_DELETE_URL=https://flow.lazychat.io/api/exec/flows/69e9bc9f7fd64cf4ca2f9a71/Hj2A7QqT1K0N
LAZYCHAT_WEBHOOK_DELETE_TOKEN=bfd4dcab6657d9a6d296efe3599e624bec424fc1dbd2df471710e717ef828e6f
LAZYCHAT_QUEUE_CONNECTION=database
LAZYCHAT_QUEUE_NAME=lazychat-webhooks
LAZYCHAT_MAX_RETRIES=3
LAZYCHAT_RETRY_DELAY=30
LAZYCHAT_TIMEOUT=10
LAZYCHAT_NOTIFY_ON_FAILURE=true
LAZYCHAT_ADMIN_EMAIL=admin@hooknhunt.com
LAZYCHAT_LOG_RETENTION_DAYS=30
